---
import { site } from "../content/site";

const isCurrent = (period: string) => /present/i.test(period);
---

{site.experience.length > 0 && (
  <section class="section" id="experience">
    <div class="section-head">
      <span class="eyebrow">01 — Career</span>
      <h2 class="title">Experience</h2>
      <span class="rule"></span>
    </div>
    <ul class="experience">
      {site.experience.map((e) => (
        <li class={isCurrent(e.period) ? "is-current" : ""}>
          <div class="exp-head">
            <span class="exp-title">
              <span class="exp-role">{e.role}</span>
              <span class="exp-company">· {e.company}</span>
              {isCurrent(e.period) && <span class="exp-now">Now</span>}
            </span>
            <span class="exp-period">{e.period}</span>
          </div>
          <p>{e.summary}</p>
        </li>
      ))}
    </ul>
  </section>
)}
