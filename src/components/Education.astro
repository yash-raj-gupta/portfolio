---
import { site } from "../content/site";
---

{site.education.length > 0 && (
  <section class="section">
    <h2>Education</h2>
    <ul class="experience">
      {site.education.map((e) => (
        <li>
          <div class="exp-head">
            <span class="exp-role">{e.degree} · {e.school}</span>
            <span class="exp-period">{e.period}</span>
          </div>
          <p>{e.detail}</p>
        </li>
      ))}
    </ul>
  </section>
)}
